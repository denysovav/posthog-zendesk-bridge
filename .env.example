# Copy to .env and fill in to switch from demo (mock) data to LIVE PostHog data.
# With these unset, the bridge serves mock data from enricher/fixtures/mock_data.json.

# --- PostHog (read path) ---
# Personal API key: PostHog > Settings > Personal API Keys (scope: read persons, events, recordings)
POSTHOG_API_KEY=
# Project ID: the number in your PostHog URL, e.g. app.posthog.com/project/12345
POSTHOG_PROJECT_ID=
# Host: https://us.posthog.com or https://eu.posthog.com
POSTHOG_HOST=https://us.posthog.com
# Project API key (phc_...), only needed for live feature-flag evaluation via /decide
POSTHOG_PROJECT_API_KEY=

# --- Zendesk (write path: posting the internal note back onto a ticket) ---
# Your subdomain: <subdomain>.zendesk.com
ZENDESK_SUBDOMAIN=
# The agent email used for API auth
ZENDESK_EMAIL=
# API token: Admin Center > Apps and integrations > Zendesk API > Token
ZENDESK_API_TOKEN=
